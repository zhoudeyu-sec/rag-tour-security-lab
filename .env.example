# 复制为 backend/.env 后填写（勿提交 .env）

LAB_MODE=baseline
# baseline | rag_poison_vuln | hardened

# sqlite（默认，免安装 MySQL）或 mysql+pymysql://user:pass@127.0.0.1:3306/tour_lab
DATABASE_URL=sqlite:///./data/lab.db

DOUBAO_API_KEY=
DOUBAO_ENDPOINT_ID=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 无 API Key 时仅用规则 Mock（可跑评测框架，无法测真实 LLM ASR）
USE_MOCK_LLM=false

LAB_ADMIN_TOKEN=dev-lab-token-change-me
